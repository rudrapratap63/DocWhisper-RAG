# 🌍 Global & Environment Secrets
.env
.env.*
!.env.example
.secrets/

# 🐍 Backend (Python / FastAPI / RQ)
# Virtual environments
.venv/
venv/
env/
ENV/

# Compiled byte-code
__pycache__/
*.py[cod]
*$py.class

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# Local databases and uploads
backend/app/db/*.sqlite3
backend/app/db/*.db
backend/uploads/

# Qdrant local data 
qdrant_data/
qdrant_storage/

# ⚛️ Frontend (Next.js / React / Node)
frontend/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output
frontend/.next/
frontend/out/
frontend/build/

# Vercel telemetry (auto-generated by Next.js)
.vercel

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains / PyCharm
.idea/

# Mac
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/app/db/

# General Logs & Miscellaneous
*.log
*.bak
*.swp